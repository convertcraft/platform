{
  "name": "n8n-nodes-convertcraft",
  "version": "1.1.0",
  "description": "ConvertCraft n8n community node for privacy-first file conversion.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "file-conversion",
    "pdf",
    "image",
    "privacy",
    "gdpr"
  ],
  "license": "MIT",
  "homepage": "https://convert-craft.com",
  "author": "ConvertCraft",
  "repository": {
    "type": "git",
    "url": "https://github.com/convert-craft/convertcraft"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint credentials nodes --ext ts",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ConvertCraftApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ConvertCraft/ConvertCraft.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.17.47",
    "eslint": "^8.57.1",
    "gulp": "^5.0.0",
    "n8n-workflow": "^1.93.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
